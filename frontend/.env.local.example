# Frontend env — copy to .env.local and fill in. NEXT_PUBLIC_* is browser-exposed.
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<public-anon-key>
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Demo / reviewer mode: set true to run with no Supabase project. The login page shows
# one-click "Enter as interviewer/candidate" buttons and invite links auto-join. Must match
# the backend's DEMO_MODE. The Supabase vars above can stay as placeholders in this mode.
NEXT_PUBLIC_DEMO_MODE=false
