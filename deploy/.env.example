# Acuity production env — copy to deploy/.env and fill in. Used by docker-compose.prod.yml.
# (deploy/.env is gitignored; deploy/.env.example is the committed template.)

# The public domain Caddy serves + gets a TLS cert for (e.g. a free DuckDNS subdomain).
# Must already point at this VM's public IP. No scheme here.
ACUITY_DOMAIN=acuity.example.duckdns.org

# --- Backend (injected into the backend container) ---

# Supabase Postgres — SESSION pooler string (port 5432, pooler host), asyncpg dialect.
# Supabase dashboard → Connect → Session pooler.
DATABASE_URL=postgresql+asyncpg://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Supabase Auth (server-side; never exposed to the browser)
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
SUPABASE_JWT_SECRET=<jwt-secret>

# Anthropic
ANTHROPIC_API_KEY=<anthropic-api-key>
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# CORS: the public origin the browser loads from (scheme + host, no trailing slash).
# Same-origin as the API here (path-based routing), so this is the site URL.
FRONTEND_ORIGIN=https://acuity.example.duckdns.org

# Never run the canned demo LLM / credential-free login in production.
DEMO_MODE=false

# --- Frontend (baked into the client bundle at BUILD time) ---
# API + WS share the domain (Caddy path-routes /auth /sessions /ws to the backend).
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
NEXT_PUBLIC_API_URL=https://acuity.example.duckdns.org
NEXT_PUBLIC_WS_URL=wss://acuity.example.duckdns.org
NEXT_PUBLIC_DEMO_MODE=false
