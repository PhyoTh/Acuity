# =============================================================================
# Acuity — shared environment variable reference
# -----------------------------------------------------------------------------
# This file DOCUMENTS every variable used across the project. Copy the relevant
# vars into the service-specific env files (never commit real values):
#   - backend/.env            (FastAPI)
#   - frontend/.env.local     (Next.js)
# See backend/.env.example and frontend/.env.local.example for the per-service
# split. Anything prefixed NEXT_PUBLIC_ is exposed to the browser.
# =============================================================================

# ---- Supabase (Auth + Postgres; single project for both) --------------------
# Project URL + keys from the Supabase dashboard (Project Settings > API).
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=<public-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key-backend-only-never-expose>
# Used by the backend to verify Supabase-issued JWTs (Project Settings > API > JWT Secret).
SUPABASE_JWT_SECRET=<jwt-secret>

# ---- Database (Supabase Postgres in prod; Docker Postgres locally) ----------
# Local dev (docker-compose): postgresql+asyncpg://acuity:acuity@localhost:5432/acuity
# Prod: use the Supabase *connection pooler* string (Project Settings > Database).
DATABASE_URL=postgresql+asyncpg://acuity:acuity@localhost:5432/acuity

# ---- Redis (WebSocket pub/sub, presence, rate limiting) ---------------------
REDIS_URL=redis://localhost:6379/0

# ---- Anthropic (LLM: chat agent, hallucinator, scorecard) -------------------
ANTHROPIC_API_KEY=<anthropic-api-key>
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ---- Frontend → backend wiring (NEXT_PUBLIC_* is browser-exposed) -----------
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<public-anon-key>
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
